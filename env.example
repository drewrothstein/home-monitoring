# Database
DATABASE_URL=postgresql://home_monitor:home_monitor_password@localhost:5432/home_monitor

# Scheduler Configuration
# How often to fetch data (in minutes)
FETCHER_INTERVAL_MINUTES=5
# Enphase API calls are limited (1k/month on Free plan, 10k on paid)
# This sets how many fetch cycles between Enphase API calls
# Default: 3 (every 15 minutes when using 5-minute fetch interval)
ENPHASE_FETCH_INTERVAL_CYCLES=3

# Enphase API Credentials
# ============================================
#
# MULTI-APP MODE (Recommended for higher API limits)
# ============================================
# Enphase's free tier has limited API calls (1k/month per app).
# To increase limits, create multiple apps and rotate between them.
#
# Step 1: Create N apps at https://developer-v4.enphase.com/
#   - Sign up/login at the Enphase Developer Portal
#   - Create multiple applications (e.g., 3 apps for 3x the API limit)
#   - Each app gets: API Key, Client ID, Client Secret
#
# Step 2: Configure each app in this file:
#   ENPHASE_APP_1_API_KEY=...
#   ENPHASE_APP_1_CLIENT_ID=...
#   ENPHASE_APP_1_CLIENT_SECRET=...
#   ENPHASE_APP_2_API_KEY=...
#   ... etc
#
# Step 3: Authorize each app (one-time per app):
#   make enphase-authorize APP=1
#   # Visit URL, authorize, get code
#   make enphase-exchange APP=1 CODE=xxxxx
#   # Repeat for apps 2, 3, etc.
#
# The system automatically:
#   - Rotates between apps (round-robin)
#   - Tracks API calls per app
#   - Fails over to next app if one hits rate limits
#   - Refreshes tokens per app when they expire
#
# Example: 3 apps configuration
# ENPHASE_APP_1_API_KEY=your_api_key_1
# ENPHASE_APP_1_CLIENT_ID=your_client_id_1
# ENPHASE_APP_1_CLIENT_SECRET=your_client_secret_1
#
# ENPHASE_APP_2_API_KEY=your_api_key_2
# ENPHASE_APP_2_CLIENT_ID=your_client_id_2
# ENPHASE_APP_2_CLIENT_SECRET=your_client_secret_2
#
# ENPHASE_APP_3_API_KEY=your_api_key_3
# ENPHASE_APP_3_CLIENT_ID=your_client_id_3
# ENPHASE_APP_3_CLIENT_SECRET=your_client_secret_3

# LEGACY SINGLE-APP MODE (Backward Compatible)
# ============================================
# If you only have one app, you can use the original format:
ENPHASE_API_KEY=your_enphase_api_key_here
ENPHASE_CLIENT_ID=your_enphase_client_id_here
ENPHASE_CLIENT_SECRET=your_enphase_client_secret_here
#
# Setup steps for legacy mode:
#   1. Set credentials above
#   2. make enphase-authorize
#   3. Visit URL, authorize, get code
#   4. make enphase-exchange CODE=your_code
#
# Note: Access tokens are stored in the database, not in .env
# Tokens are automatically refreshed when they expire

# ENPHASE LOCAL GATEWAY API (Optional, requires local network access)
# ============================================
# Local gateway APIs provide richer data than cloud APIs, including consumption data.
# Tokens are valid for 1 year for system owners.
#
# Step 1: Set your Enlighten (consumer) account credentials below
#   These are your normal Enphase app login credentials (NOT developer portal)
#
# Step 2: Store initial token for each gateway:
#   Visit https://entrez.enphaseenergy.com/, log in, and generate a token
#   make enphase-gateway-store SERIAL=<gateway_serial> HOST=<gateway_ip> TOKEN=<token>
#
# Step 3: Token auto-refresh:
#   If Enlighten credentials are configured, tokens will be automatically
#   refreshed when they are within 30 days of expiration.
#
# Note: The gateway serial number is printed on your Enphase IQ Gateway device
ENPHASE_ENLIGHTEN_USERNAME=your_enlighten_email@example.com
ENPHASE_ENLIGHTEN_PASSWORD=your_enlighten_password_here

# OpenWeather API Key
# Global API key (can be shared across locations)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Tempest API Credentials
# Global credentials (used for all sites)
TEMPEST_TOKEN=your_tempest_token_here

# Teslemetry API Credentials
# Teslemetry provides simplified access to Tesla Fleet API
# Sign up at https://teslemetry.com/login and get your API key from the console
# Global credentials (used for all sites)
TESLEMETRY_API_KEY=your_teslemetry_api_key_here

# Rachio Sprinkler Controller API Credentials
# ============================================
# Step 1: Get your API key from Rachio:
#   - Log in at https://app.rach.io/
#   - Go to Account Settings
#   - Click "Get API Key"
#
# Step 2: Get your device ID:
#   - The device ID can be found in the Rachio app or by calling the API
#   - You can also use the API to list devices (see rachio.py for details)
#
# Global credential (used for all sites)
RACHIO_API_KEY=your_rachio_api_key_here

# Flume Water Meter API Credentials
# ============================================
# Step 1: Create API credentials at https://portal.flumewater.com/
#   - Log in to your Flume account
#   - Go to Settings > API Access
#   - Create a new personal API client
#   - You'll receive: Client ID and Client Secret
#
# Step 2: Set credentials in this file (see below)
#
# Step 3: Get your initial access token:
#   make flume-token
#   (You will be prompted for your password securely)
#
# Step 4: Token refresh (automatic):
#   - Tokens are automatically refreshed when they expire
#   - No manual intervention required once tokens are stored in the database
#
# Global credentials (used for all sites)
# NOTE: Access tokens and refresh tokens are stored in the database, not in env vars
# Only Client ID and Client Secret need to be in .env (required for token refresh)
FLUME_CLIENT_ID=your_flume_client_id_here
FLUME_CLIENT_SECRET=your_flume_client_secret_here
# Username is only needed for initial token setup (password will be prompted)
FLUME_USERNAME=your_flume_email@example.com

# Tank Utility (Generac) Propane Tank Monitor API Credentials
# ============================================
# Your Tank Utility account credentials from https://app.tankutility.com/
# These are the same email/password you use to log into the Tank Utility app
#
# Note: Tank Utility was acquired by ANOVA and is no longer part of Generac.
# The legacy API may eventually be deprecated.
TANK_UTILITY_EMAIL=your_tankutility_email@example.com
TANK_UTILITY_PASSWORD=your_tankutility_password_here

# iAqualink Pool Controller API Credentials
# ============================================
# Your iAqualink account credentials from https://www.iaqualink.com/
# These are the same email/password you use to log into the iAqualink app
#
# Note: iAqualink is owned by Zodiac Pool Systems and provides pool/spa automation
IAQUALINK_EMAIL=your_iaqualink_email@example.com
IAQUALINK_PASSWORD=your_iaqualink_password_here

# Span Power Panel Configuration
# ============================================
# Span panels are configured in sites.json with their IP addresses.
# Tokens are stored in the database (not in .env).
#
# Token setup (one-time per panel):
#   1. Open the panel door and press the door sensor button 3x
#      (within 15 seconds to unlock for 15 minutes)
#   2. Run: make span-register HOST=192.168.1.200 NAME="Main Panel"
#   3. Token is stored in database automatically
#
# The fetcher collects two types of data:
#   - Panel-level data (grid power, status): every fetch cycle (~5 min)
#   - Circuit-level data (per-circuit power, energy): configurable interval
#
# Optional: How often to fetch circuit-level data (default: 15 min)
# Cumulative energy totals are never lost - only power granularity is affected
SPAN_CIRCUIT_FETCH_INTERVAL_MINUTES=15

# Grafana dashboard annotations (Optional)
# ============================================
# Personal events for the purple "Annotations" layer are loaded from annotations.json
# in the project root (gitignored). Copy annotations.example.json as a template.
# Override path if needed:
# ANNOTATIONS_CONFIG_PATH=/path/to/annotations.json

# Remote Deployment Configuration (Optional)
# ============================================
# These settings are used for remote deployment to a Raspberry Pi or other host.
# Set these in your .env file to keep your personal deployment settings private.
# The Makefile will read these values automatically.
#
# DEPLOY_HOST: SSH connection string for your remote host
#   Example: pi@raspberry-pi.local
#   Example: user@192.168.1.100
#
# DEPLOY_CONFIG_PATH: Absolute path on remote host where config files are stored
#   This should match the project directory path on your remote host
#   Example: /home/pi/home-monitor
#   Example: /opt/home-monitor
#
# DEPLOY_HOST=pi@raspberry-pi.local
# DEPLOY_CONFIG_PATH=/home/pi/home-monitor

# HTTPS Configuration (Optional)
# ============================================
# Enable HTTPS for Grafana and/or the API service using self-signed certificates.
# Both services share the same certificates from the certs/ directory.
#
# To enable HTTPS on remote deployment:
#   make deploy-enable-https-remote
#
# This will:
#   1. Generate self-signed certificates if they don't exist
#   2. Set GF_SERVER_PROTOCOL=https and API_SSL_ENABLED=true
#   3. Restart the affected services
#
# To disable HTTPS:
#   make deploy-disable-https-remote
#
# You can also set these individually:
# GF_SERVER_PROTOCOL=https    # Enable HTTPS for Grafana (http or https)
# API_SSL_ENABLED=true        # Enable HTTPS for API service (true or false)
