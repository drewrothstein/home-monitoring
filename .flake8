[flake8]
max-line-length = 120
exclude =
    .env,
    .git,
    .venv,
    *.egg-info,
    __pycache__,
    build,
    dist,
    env,
    venv
# Ignore rules that conflict with black formatter
# E203: whitespace before ':' (conflicts with black)
# E501: line too long (handled by black)
# W503: line break before binary operator (conflicts with black)
ignore =
    E203,
    E501,
    W503
per-file-ignores =
    __init__.py:F401
